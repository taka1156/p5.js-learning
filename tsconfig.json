{
    "compilerOptions": {
      "ignoreDeprecations": "6.0",
      "baseUrl": "./",
      "target": "ESNext",
      "useDefineForClassFields": true,
      "module": "ESNext",
      "lib": ["ESNext", "DOM"],
      "strict": true,
      "sourceMap": true,
      "resolveJsonModule": true,
      "esModuleInterop": true,
      "noEmit": true,
      "noUnusedLocals": true,
      "noUnusedParameters": true,
      "noImplicitReturns": true,
      "paths": {
          "@/*":["./src/*"]
      },
      "typeRoots": ["./node_modules/@types"]
    },
    "include": ["src"]
  }
